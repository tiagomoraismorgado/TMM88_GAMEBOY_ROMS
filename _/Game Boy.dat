    <manufacturer>Acclaim</manufacturer>
    <rom name="Mortal Kombat II (U) [!].gb" size="262144" />
  </game>
  <game name="Medarot : Parts Collection 2">
    <description>Medarot: Parts Collection 2 es un juego de rol desarrollado por Natsume y publicado por Imagineer, que se lanzó en Japón en 1998.</description>
