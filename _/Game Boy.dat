    <year>1998</year>
    <manufacturer>IMax</manufacturer>
    <rom name="Berutomo Kurabu (J) [S][!].gb" size="524288" />
  </game>
  <game name="Magic Maze">
    <description>Juego de acción con toques de puzzle en el que deberemos guiar a un cubo por toda la pantalla, recogiendo los demás cubos hasta dejar el nivel vacío, mientras esquivamos y disparamos a los enemigos.</description>
    <year>1993</year>
    <manufacturer>Sachen</manufacturer>
    <rom name="Magic Maze (Sachen) [!].gb" size="32768" />
