  <game name="Pachio-kun : Game Gallery">
    <description>Gracias a su apoyo, ¡ha sido muy popular! ¡Toda la serie GB Pachio-kun está ahora empaquetada en un divertido juego! También se incluye el juego de rompecabezas "El castillo de Pachio-kun", ¡lo que duplica la alegría del juego!</description>
    <year>1996</year>
    <manufacturer>Coconuts Japan</manufacturer>
    <rom name="Pachio Kun - Game Gallery (J).gb" size="524288" />
