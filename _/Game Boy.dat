    <manufacturer>Konami</manufacturer>
    <rom name="Castlevania - Legends (UE) [S][!].gb" size="262144" />
  </game>
  <game name="Go! Go! Hitchhike">
    <description>Comience en Atenas y haga autostop hasta la línea de meta en Londres. Los equipos de una persona deben viajar por 16 grandes ciudades europeas y llegar a la línea de meta en el plazo de un año. Los equipos de 2 a 4 personas pueden elegir cualquier ciudad en la que parar y competir para llegar a Londres. Tendrás que superar el hambre, las enfermedades, las peleas y otros obstáculos para llegar a la meta con tu compañero asignado.</description>
    <year>1998</year>
    <manufacturer>J-Wing</manufacturer>
